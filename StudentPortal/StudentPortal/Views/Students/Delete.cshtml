@model StudentPortal.Models.Student

@{
    ViewData["Title"] = "Delete Student";
}

<div class="card">
    <h2 style="margin-bottom:10px">Delete Student</h2>
    <div class="muted small" style="margin-bottom:20px">⚠️ This action cannot be undone</div>

    <div style="margin-bottom:20px; padding:15px; background:#fff3cd; border-radius:4px">
        <strong>Are you sure you want to delete this student?</strong>
    </div>

    <div style="margin-bottom:15px">
        <label class="control-label"><strong>Full Name:</strong></label>
        <p>@Model.FullName</p>
    </div>
    <div style="margin-bottom:15px">
        <label class="control-label"><strong>Email:</strong></label>
        <p>@Model.Email</p>
    </div>
    <div style="margin-bottom:15px">
        <label class="control-label"><strong>Phone:</strong></label>
        <p>@Model.Phone</p>
    </div>
    <div style="margin-bottom:15px">
        <label class="control-label"><strong>Status:</strong></label>
        <p>@Model.Status</p>
    </div>
    <div style="margin-bottom:15px">
        <label class="control-label"><strong>Join Date:</strong></label>
        <p>@Model.JoinDate.ToString("yyyy-MM-dd")</p>
    </div>
    <div style="margin-bottom:20px">
        <label class="control-label"><strong>Created At:</strong></label>
        <p>@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</p>
    </div>

    <form asp-action="Delete" style="margin-bottom:0">
        <input type="hidden" asp-for="StudentId" />
        <div class="row">
            <button type="submit" class="btn" style="background-color:#dc3545; color:white">Confirm Delete</button>
            <a class="btn" asp-action="Index">Cancel</a>
        </div>
    </form>
</div>
