@model Book

@{
    ViewData["Title"] = "Delete Book";
}

<h1>Delete Book</h1>

<div class="alert alert-warning">
    <strong>Are you sure you want to delete this book?</strong>
</div>

@if (Model != null)
{
    <div class="card shadow-sm" style="max-width: 500px;">
        <div class="card-header bg-danger text-white">
            <h4 class="mb-0">@Model.Title</h4>
        </div>
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-4">Book ID</dt>
                <dd class="col-sm-8">@Model.BookId</dd>

                <dt class="col-sm-4">Title</dt>
                <dd class="col-sm-8">@Model.Title</dd>

                <dt class="col-sm-4">Author</dt>
                <dd class="col-sm-8">@Model.Author</dd>

                <dt class="col-sm-4">Price</dt>
                <dd class="col-sm-8">@Model.Price.ToString("C")</dd>
            </dl>
        </div>
        <div class="card-footer">
            <form asp-action="Delete" asp-route-id="@Model.BookId" method="post">
                <button type="submit" class="btn btn-danger">Confirm Delete</button>
                <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
            </form>
        </div>
    </div>
}
else
{
    <div class="alert alert-danger">
        Book not found.
    </div>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
}
